#!/usr/bin/env bash

set -Eeuo pipefail

if [[ "${SKIP_PRE_PUSH_CHECKS:-}" == "1" ]]; then
  echo "Skipping pre-push checks because SKIP_PRE_PUSH_CHECKS=1."
  exit 0
fi

repository_root="$(git rev-parse --show-toplevel)"
cd "$repository_root"

venv_bin_directory="$repository_root/.venv/bin"

if [[ -x "$venv_bin_directory/python" ]]; then
  python_command="$venv_bin_directory/python"
else
  python_command="$(command -v python3 || command -v python)"
fi

if [[ ! -x "$python_command" ]]; then
  echo "Python is required for the pre-push checks."
  exit 1
fi

if [[ -x "$venv_bin_directory/pyright" ]]; then
  pyright_command="$venv_bin_directory/pyright"
elif command -v pyright >/dev/null 2>&1; then
  pyright_command="$(command -v pyright)"
else
  echo "pyright is not installed. Install dev tools with: pip install -r requirements-dev.txt"
  exit 1
fi

if ! "$python_command" -m ruff --version >/dev/null 2>&1; then
  echo "ruff is not installed. Install dev tools with: pip install -r requirements-dev.txt"
  exit 1
fi

if ! "$python_command" -m pytest --version >/dev/null 2>&1; then
  echo "pytest is not installed. Install dev tools with: pip install -r requirements-dev.txt"
  exit 1
fi

run_gitleaks_detect() {
  if command -v gitleaks >/dev/null 2>&1; then
    gitleaks detect --source . --no-banner --redact
    return
  fi

  if command -v docker >/dev/null 2>&1; then
    docker run --rm \
      -v "$repository_root:/repo" \
      -w /repo \
      docker.io/zricethezav/gitleaks:v8.22.1 \
      detect --source . --no-banner --redact
    return
  fi

  echo "gitleaks is not installed and Docker is unavailable."
  echo "Install gitleaks or Docker to enable the pre-push secret scan."
  exit 1
}

echo "Running Python bytecode compilation check..."
"$python_command" -m compileall -q . -x '(^|/)(\.git|\.venv|node_modules|out|__pycache__|\.pytest_cache|\.wrangler)(/|$)'

echo "Running Ruff format check..."
"$python_command" -m ruff format --check .

echo "Running Ruff lint..."
"$python_command" -m ruff check .

echo "Running Pyright..."
"$pyright_command"

echo "Running pytest..."
set +e
"$python_command" -m pytest -q
pytest_exit_code="$?"
set -e

if [[ "$pytest_exit_code" -ne 0 && "$pytest_exit_code" -ne 5 ]]; then
  exit "$pytest_exit_code"
fi

if [[ "$pytest_exit_code" -eq 5 ]]; then
  echo "pytest collected no tests; continuing."
fi

echo "Running gitleaks..."
run_gitleaks_detect

echo "Pre-push checks passed."
